<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

    <PropertyGroup>
        <TargetFrameworks>net462;net6.0-windows;net10.0-windows</TargetFrameworks>
        <UseWPF>true</UseWPF>
        <LangVersion>14.0</LangVersion>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup>
        <title>VirtualizingWrapPanel</title>
        <Version>2.5.2</Version>
        <Authors>sbaeumlisberger</Authors>
        <Copyright>sbaeumlisberger</Copyright>
        <Description>Feature-rich implementation of a VirtualizingWrapPanel for WPF.</Description>
    </PropertyGroup>

    <!-- pack options -->

    <ItemGroup>
        <None Include="nuget/README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <PropertyGroup>
        <PackageId>VirtualizingWrapPanel</PackageId>

        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/sbaeumlisberger/VirtualizingWrapPanel</RepositoryUrl>

        <PackageProjectUrl>https://sbaeumlisberger.github.io/VirtualizingWrapPanel/docs/getting-started.html</PackageProjectUrl>

        <PackageLicenseExpression>MIT</PackageLicenseExpression>

        <PackageTags>VirtualizingWrapPanel, VirtualizingPanel, WrapPanel, GridView, Virtualization, WPF, XAML, .NET </PackageTags>

        <PackageReadmeFile>README.md</PackageReadmeFile>
        
        <PackageReleaseNotes>
- Fix #103 ArgumentOutOfRangeException when removing the last item and AllowDifferentSizedItems=true
- Fix a rare issue that the panel is not switched when a group style is applied
- Fix that the container of a removed item gets not removed when it has keyboard focus
- Fix home and end key not reliably focusing the first/last item
        </PackageReleaseNotes>

        <RootNamespace>WpfToolkit.Controls</RootNamespace>
    </PropertyGroup>

    <PropertyGroup>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

</Project>
